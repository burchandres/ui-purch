{
	"$schema": "https://biomejs.dev/schemas/2.1.3/schema.json",
	"vcs": { "enabled": false, "clientKind": "git", "useIgnoreFile": false },
	"files": { "ignoreUnknown": false },
	"formatter": {
		"enabled": true,
		"indentStyle": "tab",
		"includes": ["./src/**/*", "!dist", "!src/routeTree.gen.ts", "!biome.json"]
	},
	"linter": {
		"enabled": true,
		"rules": {
			"recommended": true,
			"suspicious": {
				"noExplicitAny": "error"
			},
			"style": {
				"useConst": "error"
			}
		},
		"includes": ["./src/**/*", "!dist", "!src/routeTree.gen.ts"]
	},
	"javascript": {
